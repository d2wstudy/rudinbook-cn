# Production GitHub OAuth App callback URL should match your deployed site root.
# If you use GitHub Pages, it is usually: https://<OWNER>.github.io/<REPO>/
VITE_GITHUB_CLIENT_ID=CHANGE_ME

# Optional: Google Fonts serif (unicode-range slices)
# VITEPRESS_GOOGLE_FONTS=1
# VITEPRESS_GOOGLE_FONTS_CSS_URL=https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;600&display=swap

VITE_WORKER_URL=CHANGE_ME
VITE_GITHUB_REPO_OWNER=CHANGE_ME
VITE_GITHUB_REPO_NAME=CHANGE_ME
